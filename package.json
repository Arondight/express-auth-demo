{
  "name": "express-auth-demo",
  "version": "0.1",
  "description": "login demo with Express.js and Vue.js",
  "repository": "https://github.com/Arondight/express-auth-demo.git",
  "homepage": "https://github.com/Arondight/express-auth-demo",
  "bugs": "https://github.com/Arondight/express-auth-demo.git/issues",
  "author": "Qin Fandong",
  "license": "MIT",
  "type": "module",
  "exports": "./app.js",
  "keywords": [
    "express",
    "login",
    "vue"
  ],
  "engines": {
    "node": ">16.0.0"
  },
  "imports": {
    "#@server/*": "./server/*/index.js",
    "#@src/*": "./src/*/index.js",
    "#server/*": "./server/*.js",
    "#src/*": "./src/*.js"
  },
  "scripts": {
    "build": "npx vite build",
    "start": "node app.js",
    "serve": "npx vite serve",
    "check": "npx eslint ./*.js ./*.html ./config/ ./podman-compose/ ./server/ ./src/",
    "format": "npx prettier --config ./.prettierrc.json -uw ./*.md ./*.js ./.*.json ./*.json ./*.html ./config/ ./podman-compose/ ./server/ ./src/",
    "update": "npx ncu -u; npm update"
  },
  "dependencies": {
    "@vitejs/plugin-vue": "6.0.5",
    "axios": "1.13.6",
    "body-parser": "2.2.2",
    "compression": "1.8.1",
    "connect-history-api-fallback": "2.0.0",
    "connect-mongodb-session": "5.0.0",
    "cors": "2.8.6",
    "crypto-js": "4.2.0",
    "element-plus": "2.13.6",
    "express": "5.2.1",
    "express-session": "1.19.0",
    "js-yaml": "4.1.1",
    "lodash": "4.17.23",
    "mongoose": "9.3.3",
    "morgan": "1.10.1",
    "unplugin-auto-import": "21.0.0",
    "unplugin-vue-components": "32.0.0",
    "vite": "8.0.3",
    "vue": "3.5.31",
    "vue-router": "5.0.4"
  },
  "devDependencies": {
    "@trivago/prettier-plugin-sort-imports": "6.0.2",
    "eslint": "9.39.4",
    "eslint-plugin-import": "2.32.0",
    "eslint-plugin-node": "11.1.0",
    "eslint-plugin-promise": "7.2.1",
    "eslint-plugin-sort-exports": "0.9.1",
    "eslint-plugin-vue": "10.8.0",
    "eslint-plugin-yml": "3.3.1",
    "npm-check-updates": "19.6.5",
    "prettier": "3.8.1"
  }
}
